<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:lpq_client.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
    x:Class="lpq_client.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    Icon="/Assets/avalonia-logo.ico"
    Title="LPQ 线性规划建模系统"
    Width="1000" Height="750"
    WindowStartupLocation="CenterScreen"
    Background="#F0F0F0">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid>
        <Grid RowDefinitions="Auto, *" Margin="10">

            <Border Grid.Row="0" BorderBrush="#888888" BorderThickness="1" Background="White"
                Margin="0,0,0,10">
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <Border Background="#E0E0E0" Padding="10,5" Width="100">
                        <TextBlock Text="问题陈述:" VerticalAlignment="Center" FontWeight="Bold" />
                    </Border>
                    <TextBox Grid.Column="1" Text="{Binding ProblemDescription}" BorderThickness="0"
                        VerticalContentAlignment="Center" Margin="5" />
                    <Button Grid.Column="2" Content="导入" Background="#4472C4" Foreground="White"
                        Margin="5" Padding="15,5" />
                </Grid>
            </Border>

            <Border Grid.Row="1" BorderBrush="#4472C4" BorderThickness="2" Background="White">
                <Grid RowDefinitions="Auto, Auto, *, Auto, Auto">

                    <Border Grid.Row="0" Background="#E6EFFF" Padding="10,5" BorderBrush="#CCCCCC"
                        BorderThickness="0,0,0,1">
                        <TextBlock Text="建模向导:" FontWeight="Bold" Foreground="#4472C4" />
                    </Border>

                    <Grid Grid.Row="1" ColumnDefinitions="Auto, *" Margin="10">
                        <StackPanel Grid.Column="0" Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="目标:" VerticalAlignment="Center" FontWeight="Bold" />
                                <RadioButton Content="max" IsChecked="{Binding IsMax}"
                                    GroupName="Obj" />
                                <RadioButton Content="min" IsChecked="{Binding !IsMax}"
                                    GroupName="Obj" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="变量数:" VerticalAlignment="Center" />
                                <NumericUpDown Value="{Binding NumVars}" Minimum="1" Width="80" />
                                <TextBlock Text="约束数:" VerticalAlignment="Center" />
                                <NumericUpDown Value="{Binding NumCons}" Minimum="1" Width="80" />
                                <Button Command="{Binding GenerateCommand}" Content="重置表格"
                                    Background="#4472C4" Foreground="White" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2" BorderBrush="#888888" BorderThickness="1" Margin="10">
                        <ScrollViewer>
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding ColHeaders}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="80" Height="30" BorderBrush="#CCCCCC"
                                                BorderThickness="0,0,1,1" Background="#F0F0F0">
                                                <TextBlock Text="{Binding}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" FontWeight="Bold" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl ItemsSource="{Binding GridRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="80" Height="30" BorderBrush="#CCCCCC"
                                                    BorderThickness="0,0,1,1" Background="#F0F0F0">
                                                    <TextBlock Text="{Binding Header}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                                </Border>
                                                <ItemsControl ItemsSource="{Binding Cells}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Width="80" Height="30"
                                                                BorderBrush="#CCCCCC"
                                                                BorderThickness="0,0,1,1"
                                                                Background="{Binding Background}">
                                                                <TextBox Text="{Binding Value}"
                                                                    IsReadOnly="{Binding IsReadOnly}"
                                                                    HorizontalContentAlignment="Center"
                                                                    VerticalContentAlignment="Center"
                                                                    BorderThickness="0"
                                                                    Background="Transparent" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                    <Border Grid.Row="3" Margin="10" BorderBrush="#CCCCCC" BorderThickness="1"
                        Padding="10" Background="#FAFAFA">
                        <StackPanel>
                            <TextBlock Text="【建模预览】" FontWeight="Bold" Foreground="#4472C4"
                                HorizontalAlignment="Center" Margin="0,0,0,5" />
                            <TextBlock Text="{Binding MathModelText}" FontFamily="Consolas"
                                HorizontalAlignment="Center" />
                            <Button Command="{Binding UpdateMathModelPreviewCommand}" Content="刷新预览"
                                HorizontalAlignment="Right" FontSize="10" />
                        </StackPanel>
                    </Border>
                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="10" Spacing="10">
                        <Button Command="{Binding SolveCommand}" Content="计算" Background="#4472C4"
                            Foreground="White" Padding="30,5" FontWeight="Bold" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        <Grid IsVisible="{Binding ShowResultPopup}" Background="#80000000">
            <Border Width="300" Height="400" Background="White" BorderBrush="#4472C4"
                BorderThickness="2" BoxShadow="0 0 20 0 #55000000">
                <Grid RowDefinitions="Auto, *, Auto">
                    <Border Grid.Row="0" Background="#E6EFFF" Padding="10">
                        <TextBlock Text="规划方案" FontWeight="Bold" HorizontalAlignment="Center" />
                    </Border>
                    <ScrollViewer Grid.Row="1" Margin="10">
                        <TextBlock Text="{Binding ResultLog}" FontFamily="Consolas" FontSize="14" />
                    </ScrollViewer>
                    <Button Grid.Row="2" Command="{Binding ClosePopupCommand}" Content="关闭"
                        HorizontalAlignment="Center" Margin="10" Background="#4472C4"
                        Foreground="White" Padding="20,5" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
