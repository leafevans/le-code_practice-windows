<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:lpq_client.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
    x:Class="lpq_client.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    Icon="/Assets/avalonia-logo.ico"
    Title="LPQ 线性规划建模系统"
    Width="1000" Height="750"
    WindowStartupLocation="CenterScreen">
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>
    <Grid RowDefinitions="Auto, Auto, *, Auto, Auto" Margin="20">
        <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,20">
            <TextBlock Text="LPQ 分布式建模系统" Theme="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="基于单纯形算法的线性规划求解器" Classes="Caption" Foreground="Gray" />
        </StackPanel>
        <Border Grid.Row="1" Theme="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,20"
            CornerRadius="8" Background="White" BoxShadow="0 2 10 0 #10000000">
            <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="问题描述:" VerticalAlignment="Center"
                    Margin="0,0,10,0" FontWeight="SemiBold" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ProblemDescription}"
                    Watermark="请输入线性规划问题描述..." Margin="0,0,10,0" />
                <Button Grid.Row="0" Grid.Column="2" Content="导入数据" />
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                    Orientation="Horizontal" Spacing="20" Margin="0,20,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="目标:" VerticalAlignment="Center" FontWeight="SemiBold" />
                        <RadioButton Content="Max" IsChecked="{Binding IsMax}" GroupName="Obj" />
                        <RadioButton Content="Min" IsChecked="{Binding !IsMax}" GroupName="Obj" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="变量数:" VerticalAlignment="Center" />
                        <NumericUpDown Value="{Binding NumVars}" Minimum="1" Maximum="10"
                            FormatString="0" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="约束数:" VerticalAlignment="Center" />
                        <NumericUpDown Value="{Binding NumCons}" Minimum="1" Maximum="10"
                            FormatString="0" />
                    </StackPanel>

                    <Button Command="{Binding GenerateCommand}" Content="生成表格" Classes="Accent" />
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="2" Theme="{StaticResource CardBorder}" Padding="0" CornerRadius="8"
            ClipToBounds="True" BorderBrush="#E0E0E0" BorderThickness="1">
            <ScrollViewer>
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding ColHeaders}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Background="#F8F9FA" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="100" Height="40" BorderBrush="#E0E0E0"
                                    BorderThickness="0,0,1,1">
                                    <TextBlock Text="{Binding}" HorizontalAlignment="Center"
                                        VerticalAlignment="Center" FontWeight="SemiBold" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding GridRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="100" Height="40" BorderBrush="#E0E0E0"
                                        BorderThickness="0,0,1,1" Background="#F8F9FA">
                                        <TextBlock Text="{Binding Header}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            FontWeight="SemiBold" />
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding Cells}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="100" Height="40"
                                                    BorderBrush="#E0E0E0" BorderThickness="0,0,1,1"
                                                    Background="{Binding Background}">
                                                    <TextBox Text="{Binding Value}"
                                                        IsReadOnly="{Binding IsReadOnly}"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        BorderThickness="0"
                                                        Background="Transparent"
                                                        CornerRadius="0" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>
        <Border Grid.Row="3" Margin="0,20,0,0" Padding="15" Background="#F8F9FA" CornerRadius="8"
            BorderBrush="#E0E0E0" BorderThickness="1">
            <StackPanel>
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="数学模型预览" FontWeight="SemiBold" Foreground="#666" />
                    <Button Grid.Column="1" Command="{Binding UpdateMathModelPreviewCommand}"
                        Content="刷新" FontSize="12" Padding="8,4" />
                </Grid>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled" Margin="0,10,0,0">
                    <SelectableTextBlock Text="{Binding MathModelText}"
                        FontFamily="Consolas, Cascadia Code, Courier New"
                        FontSize="16"
                        LineHeight="24" />
                </ScrollViewer>
            </StackPanel>
        </Border>
        <Button Grid.Row="4" Command="{Binding SolveCommand}" Content="开始计算"
            HorizontalAlignment="Right" Margin="0,20,0,0"
            Padding="30,10" FontSize="16" Classes="Accent" />
        <Grid Grid.RowSpan="5" IsVisible="{Binding ShowResultPopup}" Background="#80000000">
            <Border Width="400" Height="500" Background="White" CornerRadius="12"
                BoxShadow="0 10 30 0 #40000000">
                <Grid RowDefinitions="Auto, *, Auto" Margin="20">
                    <TextBlock Grid.Row="0" Text="计算结果"
                        Theme="{StaticResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" />
                    <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="8" Margin="0,20"
                        Padding="15">
                        <ScrollViewer>
                            <SelectableTextBlock Text="{Binding ResultLog}" FontFamily="Consolas" />
                        </ScrollViewer>
                    </Border>
                    <Button Grid.Row="2" Command="{Binding ClosePopupCommand}" Content="关闭"
                        HorizontalAlignment="Center" Width="120" />
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
